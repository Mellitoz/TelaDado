class MainActivity : ComponentActivity() {

  
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContent {
            RPGTheme(darkTheme = true){
                Surface(modifier = Modifier.fillMaxSize()) {
                    TelaRPG()
                }
           }
        }
    }
}


enum class Cena {
    INICIO,
    CAMINHO_AGUA,
    CAMINHO_FUMACA,
    FINAL_BOM,
    FINAL_RUIM,
    FINAL_BOM_2,
    FINAL_RUIM_2
}

@Composable
fun TelaRPG() {
    var cenaAtual by remember { mutableStateOf(Cena.INICIO) }
    when (cenaAtual) {
        Cena.INICIO -> CenaInicio(onEscolha = { cenaAtual = it })
        Cena.CAMINHO_AGUA -> CenaCaminhoAgua(onEscolha = { cenaAtual = it })
        Cena.CAMINHO_FUMACA -> CenaCaminhoFumaca(onEscolha = { cenaAtual = it })
        Cena.FINAL_BOM -> CenaFinalBom(onReiniciar = { cenaAtual = Cena.INICIO })
        Cena.FINAL_RUIM -> CenaFinalRuim(onReiniciar = { cenaAtual = Cena.INICIO })
        Cena.FINAL_BOM_2 -> CenaFinalBom2(onReiniciar = {cenaAtual = Cena.INICIO})
        Cena.FINAL_RUIM_2 -> CenaFinalRuim2(onReiniciar = {cenaAtual = Cena.INICIO})
    }
}

@Composable
fun CenaInicio(onEscolha: (Cena) -> Unit) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(24.dp),
        verticalArrangement = Arrangement.Center,
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        Text(
            text = "🌲 A Floresta Sombria",
            fontSize = 26.sp,
            textAlign = TextAlign.Center
        )

        Spacer(modifier = Modifier.height(16.dp))

        Text(
            text = "Você acorda no meio de uma floresta escura Não sabe como chegou aqui. " +
                    "O ar está frio e dois caminhos surgem à sua frente.",
            fontSize = 16.sp,
            textAlign = TextAlign.Center
        )

        Spacer(modifier = Modifier.height(32.dp))
        
        Button(
            onClick = { onEscolha(Cena.CAMINHO_AGUA) },
            modifier = Modifier.fillMaxWidth()
        ) {
            Text("💧 Seguir o som da água")
        }

        Spacer(modifier = Modifier.height(12.dp))

        Button(
            onClick = { onEscolha(Cena.CAMINHO_FUMACA) },
            modifier = Modifier.fillMaxWidth()
        ) {
            Text("🔥 Seguir a fumaça ao longe")
        }
    }
}


